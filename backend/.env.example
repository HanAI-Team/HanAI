DEBUG=false

DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

ANTHROPIC_API_KEY=sk-ant-api03-...

# 처방/임상사례 RAG jsonl 데이터 디렉토리 (backend/data)의 절대경로.
# 미설정시 코드가 backend/data를 자동 계산하지만, 명시해두면 경로 계산 로직이
# 바뀌어도 안전하다.
DATA_DIR=/absolute/path/to/backend/data

RTZR_CLIENT_ID=your-rtzr-client-id
RTZR_CLIENT_SECRET=your-rtzr-client-secret

# CLOVA Speech — 2026-07-20 VITO(RTZR)로 전환. 롤백 대비 보존.
CLOVA_CLIENT_ID=your-clova-client-id
CLOVA_CLIENT_SECRET=your-clova-client-secret

CODEF_CLIENT_ID=your-codef-client-id
CODEF_CLIENT_SECRET=your-codef-client-secret
CODEF_PUBLIC_KEY=

UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# 주민등록번호 암호화 키 (AES-256-GCM, base64 32바이트)
# 생성: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# 프로덕션에서는 반드시 새로 생성하여 사용
RRN_ENCRYPTION_KEY=your-rrn-encryption-key

ADMIN_API_KEY=your-admin-api-key
SENTRY_DSN=
DISCORD_WEBHOOK_URL=
